{
  "expo": {
    "name": "Pantros",
    "slug": "pantros",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pantros",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/pantros.icon",
      "bundleIdentifier": "com.onchetrit.pantros",
      "deploymentTarget": "16.4",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIDesignRequiresCompatibility": true
      }
    },
    "android": {
      "package": "com.onchetrit.pantros",
      "adaptiveIcon": {
        "backgroundColor": "#F8F7F2",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8F7F2",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to use your camera to scan barcodes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to add item images.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to use your camera to add item images."
        }
      ],
      "expo-notifications",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-status-bar",
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          }
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "on.chetrit",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbfe8c7c-c4d6-4ce4-b645-0627983f7b50"
      }
    }
  }
}

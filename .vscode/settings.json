{
  "deno.enablePaths": ["supabase/functions"],
  "deno.lint": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#b1d8bb",
    "activityBar.background": "#b1d8bb",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#9080bf",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#b1d8bb",
    "statusBar.background": "#8fc79e",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#6db681",
    "statusBarItem.remoteBackground": "#8fc79e",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#8fc79e",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#8fc79e99",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "8fc79e",
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Use conventional commit format: type(scope): description."
    },
    {
      "text": "Always write in the imperative mood (e.g., 'Add feature' instead of 'Added feature')."
    },
    {
      "text": "Keep the first line under 50 characters and capitalize the first letter."
    }
  ]
}
